{
  "name": "user-auth-system",
  "version": "1.0.0",
  "description": "Login and Registration System with Role-Based Access",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build:css": "npx tailwindcss -i ./public/input.css -o ./public/styles.css --watch",
    "build:css:prod": "npx tailwindcss -i ./public/input.css -o ./public/styles.css --minify",
    "test:admin": "node tests/test-admin-security.js",
    "test:reg": "node tests/test-registration.js",
    "test:login": "node tests/test-login.js",
    "test:rbac": "node tests/test-rbac.js",
    "test:security": "node tests/test-security.js",
    "test:all": "node tests/test-e2e.js",
    "test:e2e": "node tests/test-e2e.js"
  },
  "keywords": [
    "authentication",
    "mongodb",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.0.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "svg-captcha": "^1.4.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.22",
    "nodemon": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18"
  }
}
